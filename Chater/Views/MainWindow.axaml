<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Chater.ViewModels"
        xmlns:models="using:Chater.Models"
        xmlns:local="using:Chater.Views"
        x:Class="Chater.Views.MainWindow"
        KeyDown="OnWindowKeyDown"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Chater · AI 助手" Width="520" Height="700" MinWidth="420" MinHeight="500">
    <DockPanel Margin="12" LastChildFill="True" VerticalSpacing="8">
        <DockPanel DockPanel.Dock="Top" HorizontalSpacing="4">
            <ComboBox DockPanel.Dock="Right" ItemsSource="{Binding Skills}" SelectedItem="{Binding SelectedSkill}" PlaceholderText="选择技能">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Skill"><TextBlock Text="{Binding Name}"/></DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Menu Padding="0" Margin="0" DockPanel.Dock="Right">
                <MenuItem Padding="0" Margin="0">
                    <MenuItem.Header>
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                BorderThickness="1" Padding="6,2" CornerRadius="4">
                            <StackPanel Spacing="0">
                                <TextBlock Text="{Binding SelectedProviderDisplayName}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedModelDisplayName}" FontSize="10" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </MenuItem.Header>
                    <MenuItem.ItemsSource>
                        <Binding Path="ProviderModelMenuItems"/>
                    </MenuItem.ItemsSource>
                    <MenuItem.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProviderModelMenuItem">
                            <MenuItem Header="{Binding Name}" ItemsSource="{Binding Models}">
                                <MenuItem.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ModelMenuItem">
                                        <MenuItem Header="{Binding ModelId}" Click="OnModelMenuItemClick"/>
                                    </DataTemplate>
                                </MenuItem.ItemTemplate>
                            </MenuItem>
                        </DataTemplate>
                    </MenuItem.ItemTemplate>
                </MenuItem>
            </Menu>
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="🤖" FontSize="24"/>
                <TextBlock Text="AI 助手" FontSize="19" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>
        <DockPanel DockPanel.Dock="Top" LastChildFill="True">
            <Button DockPanel.Dock="Right" Content="新会话" Command="{Binding NewConversationCommand}"/>
            <ComboBox DockPanel.Dock="Left" ItemsSource="{Binding Conversations}"
                      SelectedItem="{Binding SelectedConversation}"
                      PlaceholderText="选择历史会话">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Conversation">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Title}"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </DockPanel>

        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Text="{Binding Draft, Mode=OneWay}" TextChanged="OnDraftTextChanged" PlaceholderText="输入内容，按 Enter 发送…" AcceptsReturn="True" MinHeight="46" TextWrapping="Wrap"/>
            <Button Grid.Column="1" Content="{Binding SendButtonText}" Command="{Binding SendOrStopCommand}" IsDefault="True" MinWidth="64"/>
        </Grid>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        <Border Grid.Row="3" Padding="12" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" CornerRadius="8">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" Padding="10" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" CornerRadius="6">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Sender}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <local:MarkdownView Markdown="{Binding Content}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
